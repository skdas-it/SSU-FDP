# =============================================================================
# ResearchMind AI – Environment Configuration
# IBM watsonx.ai Studio Credentials
# =============================================================================
# Rename this file to .env and fill in your actual credentials.
# Never commit your real .env file to version control.
# =============================================================================

# ── IBM watsonx.ai Credentials ───────────────────────────────────────────────
# Obtain from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_ibm_watsonx_api_key_here

# Obtain from: watsonx.ai Studio → Project Settings → General → Project ID
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Regional endpoint – choose the one matching your IBM Cloud region:
#   US South  : https://us-south.ml.cloud.ibm.com
#   EU DE     : https://eu-de.ml.cloud.ibm.com
#   EU GB     : https://eu-gb.ml.cloud.ibm.com
#   JP TOK    : https://jp-tok.ml.cloud.ibm.com
#   AU SYD    : https://au-syd.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ── Flask Configuration ───────────────────────────────────────────────────────
# Change to a long random string in production
SECRET_KEY=researchmind-secret-change-me-2025

# ── Model Selection (optional override) ──────────────────────────────────────
# Default model used in app.py: ibm/granite-13b-instruct-v2
# Other available IBM Granite models:
#   ibm/granite-3-8b-instruct
#   ibm/granite-7b-lab
#   ibm/granite-20b-multilingual
# WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2
